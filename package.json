{
  "name": "atlas-capture-tool",
  "version": "1.3.1",
  "description": "Atlas Capture Video Annotation Tool",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && env -u ELECTRON_RUN_AS_NODE electron .\"",
    "build": "vite build",
    "dist": "vite build && electron-builder --publish always",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.atlascapture.tool",
    "productName": "Atlas Capture Tool",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "./process_video.py",
        "to": "process_video.py"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "bowenSteve",
      "repo": "ATLAS-CAPPTURE-FRONTEND"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "extraResources": [
        {
          "from": "./process_video.exe",
          "to": "process_video.exe"
        }
      ]
    }
  }
}
